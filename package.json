{
  "name": "@rafabd1/proteus",
  "version": "1.0.1",
  "description": "A plugin for Claude Code, Codex, and OpenCode that coordinates structured, continuous vulnerability research against arbitrary codebases.",
  "type": "commonjs",
  "bin": {
    "proteus": "./dist/cli.js",
    "proteus-mcp": "./dist/mcp.js"
  },
  "files": [
    ".agents/",
    ".claude-plugin/",
    ".opencode/",
    "CHANGELOG.md",
    "dist/",
    "docs/",
    "opencode.json",
    "plugins/",
    "scripts/",
    "src/",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/sync-plugin-dist.mjs && node scripts/sync-opencode.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "changelog": "node scripts/generate-changelog.mjs",
    "install:maintainability-review": "node scripts/install-maintainability-review-skill.mjs",
    "start": "node dist/cli.js",
    "sync:opencode": "node scripts/sync-opencode.mjs",
    "release:validate": "npm test && node scripts/release-validation.mjs",
    "smoke": "npm run build && node scripts/smoke-test.mjs && node scripts/mcp-smoke-test.mjs",
    "test": "npm run check && npm run smoke"
  },
  "keywords": [
    "security-research",
    "vulnerability-research",
    "bug-bounty",
    "offensive-security",
    "codex-plugin",
    "claude-code",
    "opencode"
  ],
  "license": "GPL-3.0-or-later",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
